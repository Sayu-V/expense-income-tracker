# ============================================================
# EXPENSE & INCOME TRACKER — Environment Variables Template
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. Never commit the .env file — it is gitignored
# ============================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# HOST must be "db" (the Docker service name — do not change)
DATABASE_URL=postgresql://tracker_user:YOUR_PASSWORD_HERE@db:5432/tracker_db

# PostgreSQL container settings
# These must match the values in DATABASE_URL above
POSTGRES_USER=tracker_user
POSTGRES_PASSWORD=YOUR_PASSWORD_HERE
POSTGRES_DB=tracker_db

# Frontend API URL
# Do not change this for local development
VITE_API_URL=http://localhost:8000
